{
  "manifest_version": 3,
  "name": "GEE Autocomplete MVP",
  "version": "0.5.0",
  "description": "Autocomplete helpers for Google Earth Engine Code Editor.",
  "content_scripts": [
    {
      "matches": [
        "https://code.earthengine.google.com/*"
      ],
      "js": [
        "api-data.js",         
        "completion-core.js",  
        "inject.js"            
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle",
      "all_frames": true,
      "world": "MAIN" 
    }
  ],
  "host_permissions": [
    "https://code.earthengine.google.com/*"
  ]
}
